{
  "name": "master-the-groove",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ app/ --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "e2e": "maestro test e2e/",
    "build:dev": "eas build --profile development --platform ios",
    "build:dev-sim": "eas build --profile development-simulator --platform ios",
    "build:preview": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@supabase/supabase-js": "^2.99.1",
    "expo": "~55.0.6",
    "expo-asset": "~55.0.8",
    "expo-audio": "^55.0.8",
    "expo-constants": "~55.0.7",
    "expo-crypto": "^55.0.9",
    "expo-dev-client": "~55.0.16",
    "expo-font": "^55.0.4",
    "expo-keep-awake": "~55.0.4",
    "expo-linking": "~55.0.7",
    "expo-router": "~55.0.5",
    "expo-secure-store": "~55.0.8",
    "expo-splash-screen": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.18",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^2.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "^0.7.2",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "^55.0.11",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react-native-a11y": "^3.5.1",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
